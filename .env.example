# ─────────────────────────────────────────────────────────────────────────────
# Claude's Mineflayer bot — environment template.
# Copy to .env and edit, or just export these in your shell before `node bot.js`.
# ─────────────────────────────────────────────────────────────────────────────

# --- Minecraft connection ---------------------------------------------------

# Host of the world/server. For a single-player world "Opened to LAN" on this
# same machine, leave it as localhost.
MC_HOST=localhost

# The port the world is listening on. For a LAN world, Minecraft prints this in
# chat when you Open to LAN ("Local game hosted on port NNNNN") — and it changes
# every time you re-open, so check it each session. 25565 is the default for a
# dedicated server.
MC_PORT=25565

# Minecraft version to speak.
#   - Set an explicit version (e.g. 1.21.4) to force it.
#   - Set to "auto" to let mineflayer negotiate the version from the server
#     handshake — the most robust option WHEN the world is within the range
#     mineflayer supports.
# CAVEAT: mineflayer lags new Minecraft releases. If your world is newer than the
# library supports (e.g. a year-scheme version like 26.2), login fails no matter
# what you set here — make a supported 1.21.x world instead. See README.md.
MC_VERSION=auto

# The bot's in-game username (offline-mode login). Shows up in chat and the tab
# list as this name.
MC_USER=Claude

# --- Local service ports ----------------------------------------------------
# NOTE: these are currently HARDCODED in bot.js (control=3000, viewer=3001) and
# are listed here for reference. Change them in bot.js if you need to.

# HTTP control API ("doing layer") — the port you curl to drive the bot.
CTRL_PORT=3000

# First-person viewer ("seeing layer"), served by prismarine-viewer. Open this
# in a browser to watch the bot.
VIEW_PORT=3001
